# AstraPay Backend - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection (use MongoDB Atlas free tier or local)
MONGO_URI=mongodb://localhost:27017/astrapay

# JWT Secret (for future auth)
JWT_SECRET=astrapay_super_secret_key_change_in_production

# Ethereum RPC (use Infura/Alchemy free tier or local node)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Simulation mode (set to true to use mock data instead of real RPC calls)
SIMULATION_MODE=true
